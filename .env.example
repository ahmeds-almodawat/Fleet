# Frontend Vite env
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY

# Supabase Edge Functions env
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY
SERVICE_ROLE_KEY=YOUR_ROTATED_SUPABASE_SERVICE_ROLE_KEY
OCRSPACE_API_KEY=YOUR_ROTATED_OCRSPACE_API_KEY

# Security hardening
# Comma-separated allowed browser origins. Include localhost only for local development.
CORS_ALLOWED_ORIGINS=https://your-production-domain.com,http://localhost:5173

# Required for scheduled/system job calls without a user JWT.
# Send it as: x-scheduler-secret: <value>
RUN_JOBS_SECRET=replace-with-a-long-random-secret

# Optional break-glass owners who can run admin-only edge actions.
OWNER_USER_IDS=

# Optional email reminders provider
RESEND_API_KEY=
